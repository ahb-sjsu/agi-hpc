# ────────────────────────────────────────────────────────────────
# halyard-table web client — environment template.
#
# Copy to `.env.local` (gitignored) for dev, or inject via Docker
# at runtime. NEXT_PUBLIC_* vars are baked into the client bundle
# at build time, so a new build is needed when they change.
# ────────────────────────────────────────────────────────────────

# LiveKit signaling WS — the browser connects here with a JWT
# minted by halyard-keeper-backend.
#
# Dev: ws://127.0.0.1:7880 (requires SSH port-forward to Atlas).
# Production: wss://halyard.atlas-sjsu.duckdns.org (via atlas-caddy).
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# halyard-state HTTP origin. The WS URL is derived from this
# automatically (http→ws). Dev: SSH port-forward 8090 → Atlas
# 127.0.0.1:8090.
NEXT_PUBLIC_STATE_HTTP=http://127.0.0.1:8090

# halyard-keeper-backend token mint endpoint. Lands in Sprint 6;
# until then this URL can point at a local stub.
NEXT_PUBLIC_TOKEN_MINT_URL=http://127.0.0.1:8091/api/livekit/token
